    <title>关于移动群智感知中的隐私保护的一些理解</title>
    <link href="http://example.com/2023/09/04/%E5%85%B3%E4%BA%8E%E7%A7%BB%E5%8A%A8%E7%BE%A4%E6%99%BA%E6%84%9F%E7%9F%A5%E4%B8%AD%E7%9A%84%E9%9A%90%E7%A7%81%E4%BF%9D%E6%8A%A4%E7%9A%84%E4%B8%80%E4%BA%9B%E7%90%86%E8%A7%A3/"/>
    <id>http://example.com/2023/09/04/%E5%85%B3%E4%BA%8E%E7%A7%BB%E5%8A%A8%E7%BE%A4%E6%99%BA%E6%84%9F%E7%9F%A5%E4%B8%AD%E7%9A%84%E9%9A%90%E7%A7%81%E4%BF%9D%E6%8A%A4%E7%9A%84%E4%B8%80%E4%BA%9B%E7%90%86%E8%A7%A3/</id>
    <published>2023-09-04T02:20:52.000Z</published>
